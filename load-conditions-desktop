<script>
(function(){

function lcrGenerate(){
  var fuel=parseInt(document.getElementById('lcr-fuel').value);
  var sleep=parseInt(document.getElementById('lcr-sleep').value);
  var engine=parseInt(document.getElementById('lcr-engine').value);
  var carryover=parseInt(document.getElementById('lcr-carryover').value);
  var recovery=parseInt(document.getElementById('lcr-recovery').value);
  var damage=parseInt(document.getElementById('lcr-damage').value);
  var spice=parseInt(document.getElementById('lcr-spice').value);
  var turbulence=parseInt(document.getElementById('lcr-turbulence').value);
  var ahead=parseInt(document.getElementById('lcr-ahead').value);
  var hits=parseInt(document.getElementById('lcr-hits').value);
  var visibility=parseInt(document.getElementById('lcr-visibility').value);
  var obstacles=parseInt(document.getElementById('lcr-obstacles').value);
  var tax=parseInt(document.getElementById('lcr-tax').value);
  var invisible=parseInt(document.getElementById('lcr-invisible').value);
  var radio=parseInt(document.getElementById('lcr-radio').value);
  var copilot=parseInt(document.getElementById('lcr-copilot').value);
  var passengers=parseInt(document.getElementById('lcr-passengers').value);
  var margin=parseInt(document.getElementById('lcr-margin').value);
  var bail=parseInt(document.getElementById('lcr-bail').value);

  var a=(fuel+sleep+(11-carryover)+(11-engine)+recovery+(11-damage)+spice)/7;
  var e=((11-turbulence)+(11-ahead)+(11-hits)+visibility+(11-obstacles)+(11-tax))/6;
  var s=((11-invisible)+radio+copilot+(11-passengers)+margin+bail)/6;
  var ov=(a+e+s)/3;

  var st,sc,sd;
  if(ov>=7.5){st='Favorable Conditions';sc='#5cb87a';sd='Your aircraft and environment are well matched today.';}
  else if(ov>=5.5){st='Manageable Conditions';sc='#e8a83a';sd='Load is present. Fly deliberately \u2014 protect fuel where you can.';}
  else if(ov>=3.5){st='Elevated Load';sc='#e8843a';sd='This is a high-cost flight. Reduce what you can. Know your exits.';}
  else{st='Critical Conditions';sc='#d4574a';sd='The mismatch today is real and significant. Stabilize first. Everything else waits.';}

  var sEl=document.getElementById('lcr-status');
  sEl.textContent=st; sEl.style.color=sc;
  document.getElementById('lcr-statusdesc').textContent=sd;

  function gc(v){ return v>=7.5?'#5cb87a':v>=5.5?'#e8a83a':v>=3.5?'#e8843a':'#d4574a'; }
  function slbl(sec,v){
    var t=v>=7.5?0:v>=5.5?1:v>=3.5?2:3;
    return[['System holding well','Some strain present','Running low','System under significant stress'],
           ['Conditions favorable','Some friction present','Rough conditions','Severe environmental mismatch'],
           ['Well resourced','Some support gaps','Thin support today','Flying without a net']][sec][t];
  }

  var thHTML='';
  [[a,0,'Aircraft'],[e,1,'Environment'],[s,2,'Support']].forEach(function(x){
    var col=gc(x[0]);
    var r=36,circ=2*Math.PI*r,dash=(x[0]/10)*circ;
    thHTML+='<div style="background:#2d2920;border:1px solid rgba(232,168,58,0.2);border-radius:8px;padding:20px 12px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:10px;">'
      +'<div style="font-family:Share Tech Mono,monospace;font-size:9px;letter-spacing:3px;color:#8a7d68;text-transform:uppercase;">'+x[2]+'</div>'
      +'<div style="position:relative;width:90px;height:90px;">'
      +'<svg width="90" height="90" viewBox="0 0 90 90" style="transform:rotate(-90deg)">'
      +'<circle cx="45" cy="45" r="'+r+'" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8"/>'
      +'<circle cx="45" cy="45" r="'+r+'" fill="none" stroke="'+col+'" stroke-width="8" stroke-dasharray="'+dash+' '+circ+'" stroke-linecap="round"/>'
      +'</svg>'
      +'<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:Share Tech Mono,monospace;font-size:22px;font-weight:700;color:'+col+';">'+x[0].toFixed(1)+'</div>'
      +'</div>'
      +'<div style="font-size:11px;color:#8a7d68;font-style:italic;text-align:center;line-height:1.4;">'+slbl(x[1],x[0])+'</div>'
      +'</div>';
  });
  document.getElementById('lcr-three').innerHTML=thHTML;

  var wc={alert:'rgba(212,87,74,0.15)|rgba(212,87,74,0.4)|#d4574a',caution:'rgba(232,168,58,0.1)|rgba(232,168,58,0.3)|#e8a83a',nominal:'rgba(92,184,122,0.1)|rgba(92,184,122,0.3)|#5cb87a'};
  var warns=[];
  if(fuel<=3)warns.push({t:'Low Fuel',c:'alert'});
  if(sleep<=3)warns.push({t:'Poor Sleep',c:'alert'});
  if(engine>=8)warns.push({t:'Engine Strain',c:'alert'});
  if(turbulence>=8)warns.push({t:'Severe Turbulence',c:'alert'});
  if(margin<=2)warns.push({t:'No Error Margin',c:'alert'});
  if(spice<=2)warns.push({t:'Instruments Unreliable',c:'alert'});
  if(carryover>=7)warns.push({t:'Heavy Carryover',c:'caution'});
  if(damage>=7)warns.push({t:'High Prior Wear',c:'caution'});
  if(invisible>=7)warns.push({t:'High Invisible Load',c:'caution'});
  if(passengers>=7)warns.push({t:'Full Cabin',c:'caution'});
  if(hits>=6)warns.push({t:'High Surprise Load',c:'caution'});
  if(bail<=3)warns.push({t:'No Exit Plan',c:'caution'});
  if(tax>=7)warns.push({t:'Heavy ADHD Tax',c:'caution'});
  if(ahead>=7)warns.push({t:'Heavy Load Ahead',c:'caution'});
  if(fuel>=7&&sleep>=7)warns.push({t:'Well Fueled',c:'nominal'});
  if(visibility>=8)warns.push({t:'Clear Visibility',c:'nominal'});
  if(copilot>=7)warns.push({t:'Solid Co-Pilot',c:'nominal'});
  if(bail>=7)warns.push({t:'Exit Options Clear',c:'nominal'});
  document.getElementById('lcr-warnings').innerHTML=warns.map(function(w){
    var p=wc[w.c].split('|');
    return '<span style="font-family:Share Tech Mono,monospace;font-size:9px;letter-spacing:1.5px;padding:4px 10px;border-radius:3px;text-transform:uppercase;background:'+p[0]+';border:1px solid '+p[1]+';color:'+p[2]+';">'+w.t+'</span>';
  }).join('');

  function act(txt){
    return '<div style="margin-top:8px;padding:8px 12px;background:rgba(255,255,255,0.03);border-radius:4px;font-size:11px;color:#8a7d68;display:flex;gap:8px;align-items:flex-start;line-height:1.6;"><span style="color:#e8a83a;flex-shrink:0;">&#8594;</span>'+txt+'</div>';
  }

  function insDiv(color, tag, text, actions){
    return '<div style="border-left:3px solid '+color+';padding:14px 16px;background:rgba(255,255,255,0.02);border-radius:0 6px 6px 0;font-size:12px;line-height:1.8;color:#e8dcc8;">'
      +'<span style="font-family:Share Tech Mono,monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#8a7d68;display:block;margin-bottom:6px;">'+tag+'</span>'
      +text
      +actions.map(act).join('')
      +'</div>';
  }

  var ins='';

  // Margin indicator
  var marginScore=(fuel+recovery+bail+margin)/4;
  var mLabel,mColor,mText;
  if(marginScore>=7.5){mLabel='Adequate Margin';mColor='#5cb87a';mText='You have some runway today. Not unlimited, but enough to absorb unexpected demands without immediate system failure.';}
  else if(marginScore>=5){mLabel='Thin Margin';mColor='#e8a83a';mText='Your margin is workable but narrow. One unexpected demand could close it quickly. Protect what you have.';}
  else if(marginScore>=3){mLabel='Very Thin Margin';mColor='#e8843a';mText='The gap between current demands and your capacity limit is small. High-risk configuration for threshold crossing.';}
  else{mLabel='No Margin';mColor='#d4574a';mText='You are at or near your capacity ceiling. Any additional demand risks a threshold event. Stabilize before anything else.';}
  ins+=insDiv(mColor,'Margin Indicator \u2014 '+mLabel,mText,[]);

  // Snapshot summary
  var snap='';
  if(ov>=7.5){snap='Today the load and your capacity are well-matched. The aircraft is equipped for the route.';}
  else if(ov>=5.5){snap='Today is a workable but loaded day. There is real weight here \u2014 it just has not exceeded your current capacity yet.';}
  else if(ov>=3.5){snap='Today the gap between what is being asked and what your system has available is significant. This is a conditions problem, not a personal failing.';}
  else{snap='Today\u2019s configuration is one of the most demanding. The mismatch between your system and your current load is at its highest. This is what critical conditions look like on the instruments.';}
  var aDiff=a-e;
  if(aDiff>2){snap+=' Your system is in better shape than your environment today. The friction is coming from outside, not from you.';}
  else if(aDiff<-2){snap+=' Your environment is actually cooperating better than your system today. The primary constraint is internal.';}
  ins+=insDiv(gc(ov),'Snapshot Summary',snap,[]);

  // Capacity vs environment
  var cveColor,cveName,cveText,cveActs;
  if(a>=6.5&&e>=6.5){cveName='Well-Matched \u2014 Both High';cveColor='#5cb87a';cveText='Your system and your environment are aligned today and both are reading well. This is the configuration where things that usually cost double actually cost what they should.';cveActs=['Use today to work on things that require cognitive runway \u2014 this is when that work is cheapest','Notice what structural conditions are producing this match \u2014 that information is replicable'];}
  else if(a<=4.5&&e<=4.5){cveName='Compound Mismatch \u2014 Both Low';cveColor='#d4574a';cveText='Both your system and your environment are strained today. There is no counterbalance. The threshold effect is most dangerous in this configuration.';cveActs=['This is a demand reduction day \u2014 identify what can be dropped, delegated, or simplified','One structural change to the environment has more leverage than any amount of internal coping today'];}
  else if(a>=6.5&&e<=4.5){cveName='Strong System, Rough Conditions';cveColor='#e8a83a';cveText='Your system is holding up well today but the environment is the source of friction. The mismatch is not in you \u2014 it is in what you are flying through.';cveActs=['Modify the environment first before reaching for internal strategies','What you are dealing with today is a conditions problem, not a capacity problem'];}
  else if(a<=4.5&&e>=6.5){cveName='Depleted System, Favorable Conditions';cveColor='#e8843a';cveText='The environment is cooperating today but your system is running low. A good day externally does not erase what the aircraft is carrying.';cveActs=['Use the favorable conditions to recover, not to increase output \u2014 this is a refueling opportunity','Resist the narrative that a good external day means your capacity should be higher'];}
  else{cveName='Mixed Conditions';cveColor='#e8a83a';cveText='Your system and environment are each showing some strain. Neither is in crisis but neither is fully resourced. This configuration requires deliberate allocation.';cveActs=['Identify the one gauge with the lowest reading and address that first \u2014 that is where today\u2019s leverage is'];}
  ins+=insDiv(cveColor,'Capacity vs. Environment \u2014 '+cveName,cveText,cveActs);

  // Feels like / helps / avoid
  var feels=[],helps=[],avoid=[];
  if(ov>=7.5){
    feels=['Tasks take roughly as long as they should','Decisions feel accessible, not exhausting','Recovery happens at a normal rate after hard moments'];
    helps=['Stay in the routine \u2014 consistency protects what is working','Use any extra capacity to build systems for harder days'];
    avoid=['Spending all available capacity without leaving reserve','Interpreting today\u2019s ease as evidence that other days were not real'];
  } else if(ov>=5.5){
    feels=['Things are manageable but heavier than they look','Recovery takes longer than usual after demands','A sense that you are keeping up but not by much'];
    helps=['Explicit pacing \u2014 build in transitions between demands','Externalizing anything that can leave working memory (lists, reminders)','Protecting the first and last hour of the day from high-demand tasks'];
    avoid=['Adding new commitments today even if they seem small','Interpreting "I\u2019m fine" as the same as "I have margin"'];
  } else if(ov>=3.5){
    feels=['Tasks that are usually automatic now require deliberate effort','Emotional reactivity that feels out of proportion to what triggered it','Everything costs more than it should'];
    helps=['Demand reduction \u2014 identify what can be dropped, delegated, or simplified before the day asks for it','Low-stimulus recovery windows even if brief','Operating from a written list rather than working memory'];
    avoid=['High-stakes decisions or irreversible commitments today','Trying to push through with effort rather than modifying the conditions','Interpreting the difficulty as a character reading rather than a conditions reading'];
  } else {
    feels=['Basic tasks feel like significant undertakings','Decision-making feels genuinely impaired, not just hard','The gap between what is expected and what is possible feels vast'];
    helps=['Survival mode protocol: identify what is non-negotiable and let everything else pause','Minimal sensory environment wherever possible','No performance \u2014 basic functioning is the only goal today'];
    avoid=['Any decision that can wait','Any conversation that requires emotional labor','Interpreting today as predictive of all days'];
  }
  var liStyle='style="margin-bottom:6px;"';
  var ulStyle='style="margin:8px 0 0 0;padding-left:18px;line-height:1.8;font-size:12px;color:#e8dcc8;"';
  ins+=insDiv(gc(ov),'What This Usually Feels Like','<ul '+ulStyle+'>'+feels.map(function(f){return '<li '+liStyle+'>'+f+'</li>';}).join('')+'</ul>',[]);
  ins+=insDiv(gc(ov),'&#9658; What Helps Most In This Configuration','<ul '+ulStyle+'>'+helps.map(function(f){return '<li '+liStyle+'>'+f+'</li>';}).join('')+'</ul>',[]);
  ins+=insDiv(gc(ov),'&#9658; What Not To Do Today','<ul '+ulStyle+'>'+avoid.map(function(f){return '<li '+liStyle+'>'+f+'</li>';}).join('')+'</ul>',[]);

  // Conditional blocks
  if(spice<=3)ins+=insDiv('#d4574a','Instrument Reliability','Your internal signal is low today. These readings may be underestimating the actual load \u2014 when interoception drops, you often do not feel how depleted you are until you have already crossed a threshold.',['Treat this report as a floor, not a ceiling \u2014 build in more margin than the numbers suggest','Check physical basics first: water, food, temperature']);
  if(sleep<=4)ins+=insDiv('#d4574a','Sleep Deficit','Poor sleep has downstream effects on every other gauge. This is not a willpower problem \u2014 sleep debt creates measurable cognitive and regulatory impairment that compounds across the day.',['Front-load cognitively demanding tasks \u2014 the deficit compounds as the day progresses','Reduce decision-making today where possible']);
  if(carryover>=6)ins+=insDiv('#e8843a','Carryover Load \u2014 Launched Behind','You started today already carrying weight from previous days. Your capacity floor is lower before this day has asked anything of you yet.',['Identify one thing from the carry that can be permanently dropped rather than postponed','Adjust today\u2019s output expectations before the day sets them for you']);
  if(invisible>=6)ins+=insDiv('#e8843a','High Invisible Load','Background mental labor consumes real capacity even when nothing is actively being done. It runs constantly and almost never gets counted when people try to understand why they are depleted.',['Externalize what you can \u2014 written lists, shared calendars, reminders \u2014 to move tracking out of your head','Ask whether this load is distributed or entirely concentrated on you']);
  if(damage>=7)ins+=insDiv('#d4574a','Prior Wear \u2014 Accumulated Damage','High prior wear means the aircraft has sustained real damage before today began. Burnout history and chronic depletion change how the system handles load in ways that do not simply reset.',['Burnout recovery requires reducing total load below what feels necessary, not just possible','Structural change is the appropriate intervention for high prior wear \u2014 not better coping']);
  if(tax>=5)ins+=insDiv('#e8a83a','ADHD Tax \u2014 Route Deviations Compounding','Every deviation from the planned route costs more fuel than the same distance on the original plan. The compounding is real and the total depletion is genuine even when no single detour seemed significant.',['Do not add anything new to today\u2019s plan','For each recurring deviation, ask whether it can be built into the route in advance so it stops being a surprise cost']);
  if(fuel<=4&&ahead>=5)ins+=insDiv('#d4574a','Low Fuel, Heavy Route Ahead','Low remaining capacity with significant known demands still ahead is a high-risk configuration. The route does not adjust for how much fuel you have left.',['Audit what is coming and identify which parts can be moved, simplified, or delegated before you reach them','If nothing can move, build in a recovery window before the hardest part \u2014 even a short one changes the threshold math']);
  if(passengers>=6&&fuel<=6)ins+=insDiv('#e8843a','Full Cabin on Low Fuel','Maintaining performance for others while running low yourself is one of the highest-cost configurations. Performing regulated when the instruments are alarming does not appear on any gauge \u2014 but it has a real cost.',['Identify what the people depending on you actually need today versus what you assume they need','Use every transition between demands as micro-recovery \u2014 even three minutes of low stimulus changes the rate of depletion']);
  if(margin<=3&&turbulence>=4)ins+=insDiv('#d4574a','No Margin in Rough Air','Low error margin in turbulent conditions is the configuration where threshold events are most likely. A small additional demand \u2014 one that would be trivial on a different day \u2014 can produce a disproportionate response.',['Defer any decision that can wait \u2014 this is accurate flight management, not avoidance','Do not schedule anything new today, and do not agree to anything that creates future obligation']);
  if(bail<=4)ins+=insDiv('#e8a83a','Exit Options Not Mapped','Knowing your emergency options before you need them changes how you fly the whole route. When exit options are unclear, the nervous system treats the entire flight as high-stakes.',['Identify one concrete option for today: who you could call, what you could cancel, where you could go to decompress','A bad-day protocol built in advance is significantly easier to use than one designed mid-crisis']);
  if(copilot<=4&&passengers>=5)ins+=insDiv('#e8a83a','Support Costing More Than It Returns','When the co-pilot dynamic requires more from you than it gives back \u2014 and the cabin is full \u2014 support stops being a resource and becomes another load item.',['Identify what kind of support you actually need today versus what is available \u2014 they may not match','If asking for help consistently costs more than not asking, that dynamic is worth examining in a lower-stakes moment']);

  document.getElementById('lcr-insights').innerHTML=ins;

  var out=document.getElementById('lcr-output');
  out.style.display='block';
  out.scrollIntoView({behavior:'smooth',block:'start'});
}

document.getElementById('lcr-gen-btn').addEventListener('click', lcrGenerate);

var IDS=['fuel','sleep','engine','carryover','recovery','damage','spice','turbulence','ahead','hits','visibility','obstacles','tax','invisible','radio','copilot','passengers','margin','bail'];
IDS.forEach(function(id){
  document.getElementById('lcr-'+id).addEventListener('input',function(){
    document.getElementById('lcr-v-'+id).textContent=this.value;
  });
});

})();
</script>
